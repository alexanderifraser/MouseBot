// PID constants
float k_p = 1.2;
float k_d = 0.8;
float k_i = 0.01;

float time_step = 0.05f; // seconds
float sum_error = 0;
float error = 0;
float previous_error = 0;

// Pin assignments
int motor_A_pin = 9;
int motor_B_pin = 10;
int left_sensor_pin = A0;
int right_sensor_pin = A1;

void setup() {
  pinMode(motor_A_pin, OUTPUT);
  pinMode(motor_B_pin, OUTPUT);
  pinMode(left_sensor_pin, INPUT);
  pinMode(right_sensor_pin, INPUT);

  Serial.begin(9600); // Debugging
}

void loop() {

  int left_sensor_value = analogRead(left_sensor_pin);
  int right_sensor_value = analogRead(right_sensor_pin);

  // Calculate error (difference between sensors)
  error = left_sensor_value - right_sensor_value;

  previous_error = error;

  sum_error += error * time_step;

  float direction = computePIDLoop();

  applyMotorControl(direction);

  delay(time_step * 1000); // Convert to milliseconds
}

float computePIDLoop(){
  float p = k_p * error;
  float d = k_d * (error - previous_error) / time_step;
  float i = k_i * sum_error;

  return p + i + d;
}

// Apply PID output to motors
void applyMotorControl(float direction){
  int base_speed = 150;

  int left_motor_speed = base_speed + direction;
  int right_motor_speed = base_speed - direction;

  left_motor_speed = constrain(left_motor_speed, 0, 255);
  right_motor_speed = constrain(right_motor_speed, 0, 255);

  analogWrite(motor_A_pin, left_motor_speed);
  analogWrite(motor_B_pin, right_motor_speed);
}
